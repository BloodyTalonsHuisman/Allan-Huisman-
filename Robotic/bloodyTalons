    def start_secure_stream(self, callback: callable):
        """
        Start secure camera stream with frame verification.
        Frames are only passed to callback if they pass security checks.
        """
        if self.is_streaming:
            return False
        
        self.cap = cv2.VideoCapture(self.camera_id)
        if not self.cap.isOpened():
            print(f"[Camera] Failed to open camera {self.camera_id}")
            return False
        
        self.is_streaming = True
        
        def stream_loop():
            while self.is_streaming:
                ret, frame = self.cap.read()
                if not ret:
                    print(f"[Camera] Failed to read frame")
                    continue
                
                self.frame_counter += 1
                
                # Calculate frame hash
                frame_hash = self._calculate_frame_hash(frame)
                
                # Check for spoofing/replacement
                if self._detect_frame_replacement(frame, frame_hash):
                    # Possible attack - log and skip this frame
                    self.spoof_attempts += 1
                    continue
                
                # Check for frequency modulation attacks
                if self._detect_frequency_modulation_attack(frame):
                    print(f"[Camera] WARNING: Frequency modulation attack detected!")
                    continue
                
                # Frame passed all checks - pass to callback
                callback(frame, frame_hash, self.frame_counter)
                
                # Small delay to prevent overwhelming
                time.sleep(0.033)  # ~30 fps
        
        self.stream_thread = threading.Thread(target=stream_loop)
        self.stream_thread.daemon = True
        self.stream_thread.start()
        
        print(f"[Camera] Secure stream started")
        return True
    
    def stop_secure_stream(self):
        """Stop secure camera stream"""
        self.is_streaming = False
        if self.stream_thread:
            self.stream_thread.join(timeout=2)
        if self.cap:
            self.cap.release()
        print(f"[Camera] Secure stream stopped")
    
    def capture_secure_frame(self) -> Optional[Tuple[np.ndarray, str]]:
        """
        Capture a single frame with verification.
        Returns (frame, frame_hash) if valid, None if attack detected.
        """
        if self.cap is None:
            self.cap = cv2.VideoCapture(self.camera_id)
        
        ret, frame = self.cap.read()
        if not ret:
            return None
        
        frame_hash = self._calculate_frame_hash(frame)
        
        # Run security checks
        if self._detect_frame_replacement(frame, frame_hash):
            return None
        
        if self._detect_frequency_modulation_attack(frame):
            print(f"[Camera] Frame rejected - frequency modulation attack")
            return None
        
        return frame, frame_hash
    
