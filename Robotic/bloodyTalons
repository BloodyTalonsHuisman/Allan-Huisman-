        self.session_lifetime = 3600  # 1 hour
        
        # Nonce tracking (prevent replay)
        self.used_nonces = deque(maxlen=10000)
        
        # Generate collective fingerprint
        self.fingerprint = hashlib.sha512(collective_seed).hexdigest()[:32]
        
        print(f"[Crypto] Quantum-resistant encryption initialized")
        print(f"[Crypto] Collective fingerprint: {self.fingerprint[:16]}...")
    
    def _get_session_key(self) -> bytes:
        """Get or rotate session key"""
        if self.session_key is None or (time.time() - self.session_created) > self.session_lifetime:
            # Generate new session key
            self.session_key = secrets.token_bytes(32)
            self.session_created = time.time()
