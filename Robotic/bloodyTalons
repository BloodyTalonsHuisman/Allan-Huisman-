        padding = secrets.token_bytes(padding_length)
        
        # XOR with obfuscation key
        key_repeated = (self.obfuscation_key * (len(data) // len(self.obfuscation_key) + 1))[:len(data)]
        obfuscated = bytes(a ^ b for a, b in zip(data + padding, key_repeated[:len(data) + padding_length]))
        
        return obfuscated
    
    def _deobfuscate_traffic(self, obfuscated: bytes) -> bytes:
        """Deobfuscate traffic pattern"""
        # XOR with obfuscation key
        key_repeated = (self.obfuscation_key * (len(obfuscated) // len(self.obfuscation_key) + 1))[:len(obfuscated)]
        deobfuscated = bytes(a ^ b for a, b in zip(obfuscated, key_repeated))
        
        # Remove padding (simplified - would need proper length encoding)
        return deobfuscated
    
    def create_secure_tunnel(self, target_ip: str, target_port: int) -> Optional[socket.socket]:
        """Create encrypted tunnel to trusted endpoint"""
        # Check if IP is blocked
        if target_ip in self.blocked_ips:
            print(f"[Network] Connection to blocked IP {target_ip} rejected")
            return None
        
        # Check if IP is trusted (or allow if no trust list)
        if self.trusted_ips and target_ip not in self.trusted_ips:
            print(f"[Network] Connection to untrusted IP {target_ip} rejected")
            return None
        
        try:
            # Create socket with TLS
            context = ssl.create_default_context()
            context.check_hostname = False
            context.verify_mode = ssl.CERT_REQUIRED
            
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(5)
            
            # Wrap with TLS
            secure_sock = context.wrap_socket(sock, server_hostname=target_ip)
            secure_sock.connect((target_ip, target_port))
            
            # Track connection
            connection_id = f"{target_ip}:{target_port}"
            self.active_connections[connection_id] = {
                'socket': secure_sock,
                'created': time.time(),
                'bytes_sent': 0,
                'bytes_recv': 0
            }
            
            return secure_sock
            
        except Exception as e:
            print(f"[Network] Tunnel creation failed: {e}")
            return None
    
    def send_secure(self, sock: socket.socket, data: Dict) -> bool:
        """Send encrypted data through secure tunnel"""
        try:
            # Serialize and encrypt
            json_data = json.dumps(data).encode()
            
            # Obfuscate traffic pattern
            obfuscated = self._obfuscate_traffic(json_data)
            
            # Send length then data
            length = len(obfuscated).to_bytes(4, 'big')
            sock.send(length + obfuscated)
            
            return True
            
        except Exception as e:
            print(f"[Network] Send failed: {e}")
            return False
    
    def receive_secure(self, sock: socket.socket) -> Optional[Dict]:
        """Receive and decrypt data from secure tunnel"""
        try:
            # Receive length
            length_bytes = sock.recv(4)
            if not length_bytes:
                return None
            
            length = int.from_bytes(length_bytes, 'big')
            
            # Receive data
            data = b''
            while len(data) < length:
                chunk = sock.recv(min(4096, length - len(data)))
                if not chunk:
                    return None
                data += chunk
            
            # Deobfuscate and parse
            deobfuscated = self._deobfuscate_traffic(data)
            return json.loads(deobfuscated.decode())
            
        except Exception as e:
            print(f"[Network] Receive failed: {e}")
            return None
    
