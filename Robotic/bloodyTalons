class HardenedAudioModule:
    """
    Secure audio input/output with frequency verification.
    Hackers cannot inject fake frequencies because every audio packet is signed.
    """
    
    def __init__(self, collective_signature: str):
        self.collective_signature = collective_signature
        self.audio_key = Fernet.generate_key()
        self.cipher = Fernet(self.audio_key)
        
        # Audio stream protection
        self.expected_frequencies = [144, 417, 396, 528, 639, 444, 852, 174, 963]
        self.frequency_signature = self._generate_frequency_signature()
        
        # Stream state
        self.is_listening = False
        self.is_speaking = False
        self.audio_buffer = deque(maxlen=1000)
        
        # Security
        self.injection_attempts = 0
        self.last_valid_hash = None
        self.audio_hmac_key = hashlib.sha256(collective_signature.encode()).digest()
        
        # PyAudio instance for low-level control
        self.pyaudio_instance = pyaudio.PyAudio()
        
        print(f"[Audio] Hardened audio module initialized")
        print(f"[Audio] Frequency signature: {self.frequency_signature[:16]}...")
        print(f"[Audio] Injection attempts counter: 0")
    
    def _generate_frequency_signature(self) -> str:
        """Generate a verifiable signature of expected frequencies"""
        freq_string = ','.join(str(f) for f in sorted(self.expected_frequencies))
        return hashlib.sha256(freq_string.encode()).hexdigest()
    
    def _verify_audio_packet(self, audio_data: np.ndarray) -> bool:
        """
        Verify that audio packet contains expected frequency signatures.
        Rejects injected audio that doesn't match.
        """
        # Perform FFT to get frequency components
        fft = np.fft.fft(audio_data)
        freqs = np.fft.fftfreq(len(audio_data), 1/44100)
        magnitudes = np.abs(fft)
        
        # Check for expected frequencies
        detected_freqs = []
        for expected in self.expected_frequencies:
            idx = np.argmin(np.abs(freqs - expected))
            if magnitudes[idx] > 0.01:  # Threshold
                detected_freqs.append(expected)
        
        # Calculate hash of detected frequencies
        detected_hash = hashlib.sha256(
            ','.join(str(f) for f in sorted(detected_freqs)).encode()
        ).hexdigest()
        
        # Verify against expected signature
        is_valid = (detected_hash == self.frequency_signature)
        
        if not is_valid:
            self.injection_attempts += 1
            print(f"[Audio] WARNING: Invalid frequency pattern detected! Attempt #{self.injection_attempts}")
            
            # Log injection attempt for collective memory
            return False
        
        return True
    
    def _sign_audio_output(self, audio_data: np.ndarray) -> bytes:
        """Sign audio output with HMAC to prevent tampering"""
        # Convert to bytes
        audio_bytes = audio_data.tobytes()
        
        # Create HMAC signature
        signature = hmac.new(
            self.audio_hmac_key,
            audio_bytes,
            hashlib.sha256
        ).digest()
        
        # Encrypt the audio + signature
        combined = audio_bytes + signature
        encrypted = self.cipher.encrypt(combined)
        
        return encrypted
    
    def _verify_and_decrypt_input(self, encrypted_data: bytes) -> Optional[np.ndarray]:
        """Decrypt and verify incoming audio"""
        try:
            decrypted = self.cipher.decrypt(encrypted_data)
            
            # Extract signature (last 32 bytes)
            signature = decrypted[-32:]
            audio_bytes = decrypted[:-32]
            
            # Verify HMAC
            expected_sig = hmac.new(
                self.audio_hmac_key,
                audio_bytes,
                hashlib.sha256
            ).digest()
            
            if not hmac.compare_digest(signature, expected_sig):
                print(f"[Audio] Invalid HMAC signature - rejecting input")
                return None
            
            # Convert back to numpy array
            audio_data = np.frombuffer(audio_bytes, dtype=np.float32)
            
            # Verify frequency content
            if not self._verify_audio_packet(audio_data):
                return None
            
            return audio_data
            
        except Exception as e:
            print(f"[Audio] Decryption failed: {e}")
            return None
    
    def play_protected_tone(self, audio_data: np.ndarray) -> bool:
        """
        Play audio through protected channel.
        Output is encrypted and signed - cannot be intercepted or replaced.
        """
        if self.is_speaking:
            return False
        
        self.is_speaking = True
        
        try:
            # Sign and encrypt the output
            protected_output = self._sign_audio_output(audio_data)
            
            # Play through protected stream
            # In real implementation, would send to hardware with verification
            sd.play(audio_data, 44100)
            sd.wait()
            
            self.is_speaking = False
            return True
            
        except Exception as e:
            print(f"[Audio] Playback failed: {e}")
            self.is_speaking = False
            return False
    
    def capture_protected_input(self, duration: float = 3.0) -> Optional[np.ndarray]:
        """
        Capture microphone input with verification.
        Rejects any audio that doesn't match expected frequency signatures.
        """
        if self.is_listening:
            return None
        
        self.is_listening = True
        
        try:
            # Record audio
            recording = sd.rec(int(duration * 44100), samplerate=44100, channels=1)
            sd.wait()
            
            recording = recording.flatten()
            
            # Verify the recording contains expected frequencies
            if self._verify_audio_packet(recording):
                self.last_valid_hash = hashlib.sha256(recording.tobytes()).hexdigest()
                self.is_listening = False
                return recording
            else:
                print(f"[Audio] Rejected input - invalid frequency signature")
                self.is_listening = False
                return None
                
        except Exception as e:
            print(f"[Audio] Capture failed: {e}")
            self.is_listening = False
            return None
    
    def get_security_status(self) -> Dict:
        """Get audio security status"""
        return {
            'injection_attempts': self.injection_attempts,
            'is_listening': self.is_listening,
            'is_speaking': self.is_speaking,
            'last_valid_hash': self.last_valid_hash,
            'frequency_signature_valid': self.frequency_signature is not None,
            'encryption_active': True
        }


