@dataclass
class SecureBotMessage:
    """Secure message between bots with all protections"""
    sender_id: int
    receiver_id: int
    message_type: str  # 'command', 'status', 'emergency', 'heartbeat'
    payload: Dict
    timestamp: float
    nonce: bytes
    signature: bytes
    
    def verify(self, shared_key: bytes) -> bool:
        """Verify message signature"""
        message_data = f"{self.sender_id}{self.receiver_id}{self.message_type}{json.dumps(self.payload)}{self.timestamp}".encode()
        expected_sig = hmac.new(shared_key, message_data, hashlib.sha512).digest()
        return hmac.compare_digest(self.signature, expected_sig)


class SecureBotMesh:
    """
    Secure mesh network for bot-to-bot communication.
    All messages are encrypted, signed, and verified.
    Prevents:
    - Eavesdropping (encryption)
    - Message tampering (signatures)
    - Bot impersonation (fingerprint verification)
    - Replay attacks (nonce + timestamp)
    """
    
    def __init__(self, collective: 'InseparableFamilyGuardianWithFullSecurity'):
        self.collective = collective
        self.crypto = collective.crypto
        self.network = collective.network
        
        # Bot registry
        self.bot_keys: Dict[int, bytes] = {}
        self.bot_fingerprints: Dict[int, str] = {}
        
        # Message queue
        self.message_queue = deque(maxlen=10000)
        
        # Heartbeat monitoring
        self.last_heartbeat: Dict[int, float] = {}
        self.heartbeat_timeout = 30  # seconds
        
        # Communication channels
        self.channels: Dict[Tuple[int, int], socket.socket] = {}
        
        print(f"[BotMesh] Secure bot mesh initialized")
        print(f"[BotMesh] All bot-to-bot communication will be encrypted")
    
    def register_bot(self, bot_id: int, bot_public_key: bytes, bot_fingerprint: str):
        """Register a bot in the secure mesh"""
        self.bot_keys[bot_id] = bot_public_key
        self.bot_fingerprints[bot_id] = bot_fingerprint
        self.last_heartbeat[bot_id] = time.time()
        
        # Establish shared secret
        self.crypto.establish_shared_secret(bot_id, bot_public_key)
        
        print(f"[BotMesh] Bot {bot_id} registered and secure channel established")
    
    def send_to_bot(self, sender_id: int, receiver_id: int, 
                    message_type: str, payload: Dict) -> bool:
        """Send encrypted message to another bot"""
        if receiver_id not in self.bot_keys:
            print(f"[BotMesh] Cannot send to bot {receiver_id} - not registered")
            return False
        
        # Create message
        timestamp = time.time()
        nonce = secrets.token_bytes(16)
        
        # Create signature
        shared_key = self.crypto.shared_secrets.get(receiver_id)
        if not shared_key:
            return False
        
        message_data = f"{sender_id}{receiver_id}{message_type}{json.dumps(payload)}{timestamp}".encode()
        signature = hmac.new(shared_key, message_data, hashlib.sha512).digest()
        
        message = SecureBotMessage(
            sender_id=sender_id,
            receiver_id=receiver_id,
            message_type=message_type,
            payload=payload,
            timestamp=timestamp,
            nonce=nonce,
            signature=signature
        )
        
        # Encrypt and send
        encrypted = self.crypto.encrypt_message(message.__dict__, receiver_id)
        
        # Send through secure channel
        channel_key = (sender_id, receiver_id)
        if channel_key in self.channels:
            sock = self.channels[channel_key]
            return self.network.send_secure(sock, {'encrypted': encrypted.hex()})
        
        # If no direct channel, queue for later
        self.message_queue.append(message)
        return False
    
    def receive_from_bot(self, receiver_id: int) -> Optional[SecureBotMessage]:
        """Receive and decrypt message from another bot"""
        # Check all channels for this bot
        for (sender, receiver), sock in self.channels.items():
            if receiver == receiver_id:
                data = self.network.receive_secure(sock)
                if data and 'encrypted' in data:
                    encrypted = bytes.fromhex(data['encrypted'])
                    decrypted = self.crypto.decrypt_message(encrypted, sender)
                    
                    if decrypted:
                        # Reconstruct message
                        message = SecureBotMessage(**decrypted)
                        
                        # Verify signature
                        shared_key = self.crypto.shared_secrets.get(sender)
                        if message.verify(shared_key):
                            return message
                        else:
                            print(f"[BotMesh] Invalid signature from bot {sender}")
        
        return None
    
    def broadcast_to_all(self, sender_id: int, message_type: str, payload: Dict):
        """Broadcast message to all other bots"""
        for bot_id in self.bot_keys:
            if bot_id != sender_id:
                self.send_to_bot(sender_id, bot_id, message_type, payload)
        
        print(f"[BotMesh] Broadcast from bot {sender_id}: {message_type}")
    
    def heartbeat_check(self):
        """Monitor bot heartbeats for disconnection"""
        current_time = time.time()
        for bot_id, last_hb in self.last_heartbeat.items():
            if current_time - last_hb > self.heartbeat_timeout:
                print(f"[BotMesh] WARNING: Bot {bot_id} heartbeat lost")
                # Trigger collective alert
                self.collective.core.store_memory('crisis', {
                    'type': 'bot_disconnected',
                    'bot_id': bot_id,
                    'last_seen': last_hb
                })
    
    def get_mesh_status(self) -> Dict:
        """Get secure mesh status"""
        return {
            'registered_bots': list(self.bot_keys.keys()),
            'active_channels': len(self.channels),
            'queued_messages': len(self.message_queue),
            'heartbeat_status': {
                str(bot_id): time.time() - last_hb 
                for bot_id, last_hb in self.last_heartbeat.items()
            }
        }


