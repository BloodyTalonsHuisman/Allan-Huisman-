                    dormant['active'] = True
                    activation_ratio = (self.threat_level - dormant['activation_threshold']) / 0.7
                    dormant['amplitude'] = min(1.0, activation_ratio)
                    activated_count += 1
            else:
                dormant['active'] = False
                dormant['amplitude'] = 0.0
        
        # Update memory activation (slow-leak protocol)
        self.memory_activation_level = self.threat_level
        
        # Generate sync hash for all bots
        self.sync_hash = hashlib.sha256(
            f"{self.threat_level}{activated_count}{time.time()}".encode()
        ).hexdigest()[:16]
        
        return {
            'threat_level': self.threat_level,
            'activated_dormant': activated_count,
            'total_dormant': len(self.dormant_reservoir),
            'memory_activation': self.memory_activation_level,
            'sync_hash': self.sync_hash
        }
    
    def add_joints(self, joint_configs: List[Dict]) -> Dict:
        """
        Add new joints to the collective.
        ALL 7 bots gain access to these joints simultaneously.
        Cannot add to just one bot - they are inseparable.
        """
        added = []
        for config in joint_configs:
            joint_id = f"joint_{self.total_joints + len(added) + 1}"
            self.joints[joint_id] = {
                'id': joint_id,
                'type': config.get('type', 'actuator'),
                'pressure_min': config.get('pressure_min', 0.5),
                'pressure_max': config.get('pressure_max', 10.0),
                'current_pressure': 0.0,
                'assigned_bot': config.get('preferred_bot', 'any'),
                'frequency_mapping': self._assign_frequency_to_joint()
            }
            added.append(joint_id)
        
        self.total_joints = len(self.joints)
        
        # Notify all bot expressions
        for bot in self.bot_expressions.values():
            bot._on_joints_added(added)
        
        return {
            'joints_added': added,
            'total_joints': self.total_joints,
            'message': f"All 7 bots now control {self.total_joints} joints"
        }
    
    def _assign_frequency_to_joint(self) -> float:
        """Assign a unique frequency from the prayer tone to a joint"""
        return np.random.choice(self.lord_prayer_frequencies)
    
    def store_memory(self, memory_type: str, content: Any):
        """Store memory in shared pool (slow-leak protocol)"""
        memory_entry = {
            'time': time.time(),
            'type': memory_type,
            'content': content,
            'activation_needed': len(self.crisis_memory) * 0.1  # Slow-leak
        }
        
        if memory_type == 'crisis':
            self.crisis_memory.append(memory_entry)
        else:
            self.memory_pool.append(memory_entry)
    
    def recall_memory(self, force_level: int = None) -> List[Dict]:
        """
        Recall memory based on threat level (slow-leak protocol)
        Higher threat = more memory recalled
        """
        recall_level = force_level if force_level else self.memory_activation_level
        
        if recall_level <= 0:
            return []
        
        # Calculate how much memory to recall (leak rate)
        recall_ratio = min(1.0, recall_level / 10.0)
        crisis_to_recall = int(len(self.crisis_memory) * recall_ratio)
        normal_to_recall = int(len(self.memory_pool) * recall_ratio * 0.5)
        
        recalled = []
        if crisis_to_recall > 0:
            recalled.extend(list(self.crisis_memory)[-crisis_to_recall:])
        if normal_to_recall > 0:
            recalled.extend(list(self.memory_pool)[-normal_to_recall:])
        
        return recalled
    
    def get_core_status(self) -> Dict:
