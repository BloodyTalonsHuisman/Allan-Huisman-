class BotExpression:
    """
    One of the 7 expressions of the shared consciousness.
    NOT a separate bot - an AVATAR of the ONE core.
    Hackers cannot isolate this because it IS the core.
    """
    
    def __init__(self, name: str, expression_id: int, core: SharedConsciousness,
                 specialty: str, physical_role: str, primary_frequency: float):
        self.name = name
        self.expression_id = expression_id
        self.core = core  # Reference to the ONE shared core
        self.specialty = specialty
        self.physical_role = physical_role
        self.primary_frequency = primary_frequency
        
        # This expression's joint assignments (subset of core.joints)
        self.assigned_joints = []
        
        # Expression-specific state (but still tied to core)
        self.is_active = True
        self.last_action = None
        
        print(f"[{self.name}] Expression awakened from the ONE core")
        print(f"   Specialty: {specialty}")
        print(f"   Role: {physical_role}")
        print(f"   Frequency: {primary_frequency} Hz")
    
    def _on_joints_added(self, new_joints: List[str]):
        """Called when new joints are added to the core"""
        # Assign some of the new joints to this expression
        for joint_id in new_joints:
            if joint_id not in self.assigned_joints:
                self.assigned_joints.append(joint_id)
        
        print(f"[{self.name}] Now controls {len(self.assigned_joints)} joints")
    
    def execute(self, action: str, target: Dict = None) -> Dict:
        """
        Execute an action through this expression.
        Uses the shared core's state.
        """
        # Get current threat from core
        threat = self.core.threat_level
        
        # Recall memory if needed (slow-leak)
        if threat >= 5:
            recalled = self.core.recall_memory()
        else:
            recalled = []
        
        # Calculate pressure based on threat and action
        pressure = self._calculate_pressure(threat, action, target)
        
        # Get dormant activation status
        active_dormant = [d for d in self.core.dormant_reservoir if d['active']]
        
        result = {
            'expression': self.name,
            'action': action,
            'pressure_kg': pressure,
            'threat_level': threat,
            'active_dormant_frequencies': len(active_dormant),
            'memory_recalled': len(recalled),
            'sync_hash': self.core.sync_hash,
            'timestamp': time.time()
        }
        
        # Store in shared memory
        self.core.store_memory('action', result)
        
        self.last_action = result
        return result
    
    def _calculate_pressure(self, threat: int, action: str, target: Dict = None) -> float:
        """Calculate safe pressure based on threat and context"""
        # Base pressure from threat
        base_pressure = 0.5 + (threat / 10.0) * 9.5  # 0.5 to 10.0
        
        # Child safety override
        if target and target.get('is_child'):
            return min(base_pressure, 2.0)  # Max 2kg around children
        
        # Action-specific adjustments
        if action == 'comfort':
            return min(base_pressure, 3.0)
        elif action == 'restrain':
            return base_pressure
        elif action == 'guide':
            return min(base_pressure, 2.0)
        elif action == 'protect':
            return min(base_pressure, 8.0)
        
        return base_pressure
    
    def get_status(self) -> Dict:
        """Get this expression's status"""
        core_status = self.core.get_core_status()
        
        return {
            'expression': self.name,
            'expression_id': self.expression_id,
            'specialty': self.specialty,
            'physical_role': self.physical_role,
            'primary_frequency': self.primary_frequency,
            'assigned_joints': len(self.assigned_joints),
            'is_active': self.is_active,
            'core': core_status
        }


