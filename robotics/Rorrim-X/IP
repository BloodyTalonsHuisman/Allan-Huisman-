        """Set threat level for ALL bots"""
        return self.core.set_threat(level)
    
    def child_protection(self, enable: bool) -> Dict:
        """Enable/disable child protection mode"""
        self.core.child_mode = enable
        return {
            'child_protection': enable,
            'max_pressure': 2.0 if enable else 10.0,
            'all_bots_affected': True
        }
    
    def emergency_all(self) -> Dict:
        """Emergency response from ALL bots"""
        self.set_threat(10)
        responses = {}
        for bot in self.bots.values():
            responses[bot.name] = bot.grip(10.0) if bot.bot_id != 3 else bot.scan()
        return {
            'emergency': True,
            'threat': 10,
            'responses': responses
        }
    
    def get_status(self) -> Dict:
        """Complete system status"""
        core_status = self.core.get_status()
        return {
            'core': core_status,
            'bots': {bot_id: bot.get_status() for bot_id, bot in self.bots.items()},
            'complete': self.bot_count == 7
        }


