        print(f"  Active Dormant: {status['active_dormant']}/{status['total_dormant']}")
        print(f"  Pressure Range: {status['pressure_range'][0]}kg - {status['pressure_range'][1]}kg")
        print(f"  Collective Signature: {status['signature']}")
        print("="*70)
    
