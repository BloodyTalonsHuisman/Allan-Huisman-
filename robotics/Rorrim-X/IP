class FamilyBot:
    """Base class for each of the 7 family guardians"""
    
    def __init__(self, bot_id: int, name: str, frequency: float, 
                 role: str, gripper_type: str, core: FamilyGuardianCore):
        self.bot_id = bot_id
        self.name = name
        self.frequency = frequency
        self.role = role
        self.gripper_type = gripper_type
        self.core = core
        
        # Actuator registry
        self.actuators = {}
        self.sensors = {}
        
        # State
        self.is_active = False
        self.last_action = None
        
        # Register with core
        core.add_bot(self)
        
        print(f"[{name}] Bot #{bot_id} initialized")
        print(f"   Frequency: {frequency} Hz")
        print(f"   Role: {role}")
        print(f"   Gripper: {gripper_type}")
    
    def add_actuator(self, name: str, joint_id: str, 
                     pressure_min: float = 0.5, pressure_max: float = 10.0):
        """Add an actuator to this bot"""
        self.actuators[name] = {
            'joint': joint_id,
            'pressure_min': pressure_min,
            'pressure_max': pressure_max,
            'current_pressure': 0.0,
            'last_trigger': 0
        }
        return self
    
    def add_sensor(self, name: str, sensor_type: str, pin: int):
        """Add a sensor to this bot"""
        self.sensors[name] = {
            'type': sensor_type,
            'pin': pin,
            'last_value': None
        }
        return self
    
    def grip(self, pressure_kg: float = None) -> Dict:
        """Execute grip with pressure control"""
        if pressure_kg is None:
            pressure_kg = self.core.calculate_pressure()
        
        # Apply child safety
        if self.core.child_mode:
            pressure_kg = min(pressure_kg, 2.0)
        
        # Clamp to safe range
        pressure_kg = max(0.5, min(10.0, pressure_kg))
        
        # Update frequency amplitude based on pressure
        freq_amplitude = pressure_kg / 10.0
        self.core.current_pressure = pressure_kg
        
        result = {
            'bot': self.name,
            'action': 'grip',
            'pressure_kg': pressure_kg,
            'frequency_amplitude': freq_amplitude,
            'threat_level': self.core.threat,
            'child_safe': self.core.child_mode,
            'timestamp': time.time()
        }
        
        self.last_action = result
        self.core.store_memory(result)
        return result
    
    def release(self) -> Dict:
        """Release grip"""
        result = {
            'bot': self.name,
            'action': 'release',
            'pressure_kg': 0.0,
            'timestamp': time.time()
        }
        self.last_action = result
        self.core.current_pressure = 0.0
        return result
    
    def get_status(self) -> Dict:
        return {
            'name': self.name,
            'bot_id': self.bot_id,
            'frequency': self.frequency,
            'role': self.role,
            'active': self.is_active,
            'actuators': len(self.actuators),
            'sensors': len(self.sensors),
            'last_action': self.last_action
        }


