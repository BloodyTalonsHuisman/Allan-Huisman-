    def add_bot(self, bot) -> Dict:
        """Add one bot to the system"""
        bot_id = bot.bot_id
        
        if bot_id in self.bots:
            return {'error': f'Bot {bot.name} already exists'}
        
        self.bots[bot_id] = bot
        self.bot_count += 1
        bot.is_active = True
        
        result = {
            'status': 'added',
            'bot': bot.name,
            'bot_id': bot_id,
            'total_bots': self.bot_count,
            'remaining': 7 - self.bot_count,
            'system_complete': self.bot_count == 7
        }
        
        print(f"\n[+] Bot #{bot_id} '{bot.name}' added")
        print(f"    Total: {self.bot_count}/7 bots active")
        
        if self.bot_count == 7:
            print("\n" + "!"*70)
            print("SYSTEM COMPLETE! All 7 guardians are now ONE")
            print("!"*70)
            self._show_complete_status()
        
        return result
    
    def _show_complete_status(self):
